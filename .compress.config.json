{
    "TargetDirectory": "{projectname}",
    "ArchivePath": "{projectname}-{datetime}-{branch}-{commit}.zip",
    "CleanTargetDirectory": true,
    "Exclude": [
        "\\.compress.config.json",
        "\\.editorconfig",
        "\\.gitattributes",
        "\\.git\\*",
        "\\.idea\\*",
        "\\dist\\*",
        "\\build\\*",
        "\\.venv\\*",
        "\\venv\\*",
        "*\\__pycache__\\*",
        "\\.pytest_cache\\*",
        "\\.mypy_cache\\*",
        "\\.ruff_cache\\*",
        "\\*.egg-info\\*",
        "\\diff.txt",
        "*.pyc",
        "*.pyo",
        "*.pyd",
        "*.log",
        "\\.coverage",
        "\\coverage.xml",
        "\\.env"
    ]
}
